PORT=3000
NODE_ENV=development

# Set either TMUX_WEB_DEV=1 or TMUX_WEB_MODE=development when running in dev mode.
TMUX_WEB_DEV=1
# TMUX_WEB_MODE=development

# Optional override used by extension subprocesses.
TMUX_WEB_DATA_ROOT=

# Colon-separated list of directories where file read/write/delete is allowed.
# Leave unset (or empty) to disable the file API entirely.
# TMUX_WEB_FS_ROOTS=/home/me/projects:/var/log/myapp
